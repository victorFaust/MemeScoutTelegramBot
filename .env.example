# Telegram Bot (set these in Render dashboard as secrets)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Chains to monitor
CHAINS=solana,robinhood

# Global settings
DEDUP_COOLDOWN_HOURS=6
SAFETY_CHECK_CACHE_HOURS=1
SKIP_ON_SAFETY_CHECK_FAILURE=true

# Database path (optional -- defaults to ./alerts.db)
# On Render with persistent disk, set to e.g. /var/data/alerts.db
# DB_PATH=/var/data/alerts.db

# Logging (use /tmp on Render ephemeral filesystem)
LOG_FILE=bot.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# Per-chain filter thresholds are in chain_config.yaml (not here)
