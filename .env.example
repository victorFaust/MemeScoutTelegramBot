# Telegram Bot Configuration (secrets -- keep in .env only)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Chains to monitor (comma-separated)
CHAINS=solana,base

# Polling interval in seconds
POLL_INTERVAL_SECONDS=180

# Dedup cooldown in hours
DEDUP_COOLDOWN_HOURS=6

# Safety check cache duration (hours)
SAFETY_CHECK_CACHE_HOURS=1

# If safety check API fails: true = skip alert (safer), false = send with warning
SKIP_ON_SAFETY_CHECK_FAILURE=true

# Logging
LOG_FILE=bot.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# NOTE: Per-chain filter thresholds are in chain_config.yaml (not here).
