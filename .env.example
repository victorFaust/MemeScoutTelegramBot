# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Chains to monitor (comma-separated, e.g. solana,base,ethereum)
CHAINS=solana,base

# Polling interval in seconds
POLL_INTERVAL_SECONDS=180

# --- Filter Thresholds ---
MIN_LIQUIDITY_USD=5000
MAX_LIQUIDITY_USD=50000
MAX_MARKET_CAP=500000
MAX_PAIR_AGE_HOURS=168
MIN_VOLUME_LIQUIDITY_RATIO=0.5
MIN_TX_COUNT_1H=10
MIN_PRICE_CHANGE_1H=0.0
MIN_PRICE_CHANGE_6H=0.0

# Dedup cooldown in hours
DEDUP_COOLDOWN_HOURS=6

# Minimum score to trigger an alert (0-100)
MIN_ALERT_SCORE=50

# Logging
LOG_FILE=bot.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
